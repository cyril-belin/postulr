# Postulr — variables d'environnement
# Copier en .env et renseigner. Toutes les var sont lues via useRuntimeConfig (AGENTS.md §9).
# Préfixe NUXT_PUBLIC_ pour les var exposées côté client.

# --- Base de données (NeonDB) ---
NUXT_DATABASE_URL=
# --- Auth + Billing (Clerk) ---
NUXT_CLERK_SECRET_KEY=
NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NUXT_CLERK_WEBHOOK_SECRET=

# --- Storage PDF (Vercel Blob) ---
NUXT_BLOB_READ_WRITE_TOKEN=

# --- LLM (OpenAI — modèle gpt-5.4-nano derrière abstraction) ---
NUXT_OPENAI_API_KEY=

# --- Background jobs (Inngest) ---
NUXT_INNGEST_EVENT_KEY=
NUXT_INNGEST_SIGNING_KEY=

# --- App ---
NUXT_PUBLIC_APP_URL=http://localhost:3000

# --- Agrégation offres (F5) ---
NUXT_FRANCE_TRAVAIL_CLIENT_ID=
NUXT_FRANCE_TRAVAIL_CLIENT_SECRET=
NUXT_ADZUNA_APP_ID=
NUXT_ADZUNA_API_KEY=

# --- Dev Inngest ---
# Mettre à 1 pour pointer le client Inngest vers le dev server local (localhost:8288)
NUXT_INNGEST_DEV=1
